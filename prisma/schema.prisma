generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ARBITRO
  VOCAL
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(VOCAL)
  createdAt DateTime @default(now())
}

model Player {
  id                   String       @id @default(uuid())
  name                 String
  number               Int
  teamId               String?
  status               PlayerStatus @default(BENCHED)
  team                 Team?        @relation(fields: [teamId], references: [id])
  createdAt            DateTime     @default(now())
  eventMatches         EventMatch[] @relation("OutgoingPlayer")
  incomingEventMatches EventMatch[] @relation("IncomingPlayer")

  @@unique([name, number])
}

model Team {
  id             String   @id @default(uuid())
  name           String   @unique
  players        Player[]
  createdAt      DateTime @default(now())
  matchesAsLocal Match[]  @relation("LocalTeam")
  matchesAsAway  Match[]  @relation("AwayTeam")
}

model Match {
  id            String         @id @default(uuid())
  localTeamId   String
  awayTeamId    String
  status        MatchStatus    @default(PROGRAMMED)
  half          Int            @default(1)
  createdAt     DateTime
  localTeam     Team           @relation("LocalTeam", fields: [localTeamId], references: [id])
  awayTeam      Team           @relation("AwayTeam", fields: [awayTeamId], references: [id])
  timeIntervals TimeInterval[]
  events        EventMatch[]
}

model TimeInterval {
  id        String    @id @default(uuid())
  matchId   String
  half      Int
  startedAt DateTime
  stoppedAt DateTime?
  match     Match     @relation(fields: [matchId], references: [id])
}

model EventMatch {
  id               String    @id @default(uuid())
  matchId          String
  playerId         String
  incomingPlayerId String?
  type             EventType
  minute           Int
  half             Int
  createdAt        DateTime  @default(now())
  match            Match     @relation(fields: [matchId], references: [id])
  player           Player    @relation("OutgoingPlayer", fields: [playerId], references: [id])
  incomingPlayer   Player?   @relation("IncomingPlayer", fields: [incomingPlayerId], references: [id])
}

enum PlayerStatus {
  PLAYING
  BENCHED
}

enum MatchStatus {
  PROGRAMMED
  IN_PROGRESS
  STOPPED
  ENDED
}

enum EventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
}
